{
    "name": "superadmin",
    "version": "1.0.0",
    "author": "Michał Kędrzyński <m.kedrzynski@gmail.com>",
    "repository": "https://github.com/kedrzu/superadmin.git",
    "bin": "./bin/cli.js",
    "files": [
        "dist",
        "bin"
    ],
    "type": "module",
    "sideEffects": false,
    "main": "./dist/core.js",
    "module": "./dist/core.js",
    "types": "./dist/core.d.ts",
    "exports": {
        ".": {
            "types": "./dist/core.d.ts",
            "default": "./dist/core.js"
        },
        "./client": {
            "types": "./dist/client.d.ts",
            "default": "./dist/client.js"
        },
        "./server": {
            "types": "./dist/server.d.ts",
            "default": "./dist/server.js"
        },
        "./schema": {
            "types": "./dist/schema.d.ts",
            "default": "./dist/schema.js"
        },
        "./validation": {
            "types": "./dist/validation.d.ts",
            "default": "./dist/validation.js"
        },
        "./ioc": {
            "types": "./dist/ioc.d.ts",
            "default": "./dist/ioc.js"
        },
        "./config": {
            "types": "./dist/config.d.ts",
            "default": "./dist/config.js"
        }
    },
    "scripts": {
        "lint": "eslint . --fix --cache",
        "format": "oxfmt ./src > /dev/null"
    },
    "dependencies": {
        "@nzyme/cli": "0.14.0",
        "@nzyme/ioc": "0.14.0",
        "@nzyme/project-utils": "0.14.0",
        "@nzyme/utils": "0.14.0",
        "@superadmin/client": "workspace:*",
        "@superadmin/config": "*",
        "@superadmin/core": "workspace:*",
        "@superadmin/devkit": "*",
        "@superadmin/ioc": "workspace:*",
        "@superadmin/schema": "workspace:*",
        "@superadmin/server": "workspace:*",
        "@superadmin/tsconfig": "*",
        "@superadmin/validation": "workspace:*"
    },
    "devDependencies": {
        "@nzyme/eslint": "0.14.0",
        "@types/node": "25.5.0",
        "eslint": "10.1.0",
        "oxfmt": "0.46.0"
    }
}

{
    "name": "@superadmin/validation",
    "version": "1.0.0",
    "author": "Michał Kędrzyński <m.kedrzynski@gmail.com>",
    "repository": "https://github.com/kedrzu/superadmin.git",
    "type": "module",
    "sideEffects": false,
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./*.js": {
            "types": "./dist/*.d.ts",
            "import": "./dist/*.js",
            "source": "./src/*.ts",
            "default": "./dist/*.js"
        }
    },
    "scripts": {
        "lint": "eslint . --fix --cache",
        "format": "oxfmt ./src > /dev/null"
    },
    "dependencies": {
        "@nzyme/validation": "0.14.0"
    },
    "devDependencies": {
        "@superadmin/tsconfig": "*",
        "@types/node": "25.5.0",
        "eslint": "10.1.0",
        "oxfmt": "0.46.0"
    }
}

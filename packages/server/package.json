{
    "name": "@superadmin/server",
    "version": "1.0.0",
    "author": "Michał Kędrzyński <m.kedrzynski@gmail.com>",
    "repository": "https://github.com/kedrzu/superadmin.git",
    "type": "module",
    "sideEffects": false,
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./entry": {
            "types": "./dist/entry.d.ts",
            "import": "./dist/entry.js",
            "default": "./dist/entry.js"
        },
        "./entry-dev": {
            "types": "./dist/entry-dev.d.ts",
            "import": "./dist/entry-dev.js",
            "default": "./dist/entry-dev.js"
        },
        "./module": {
            "types": "./dist/module.d.ts",
            "import": "./dist/module.js",
            "default": "./dist/module.js"
        },
        "./*.js": {
            "types": "./dist/*.d.ts",
            "import": "./dist/*.js",
            "source": "./src/*.ts",
            "default": "./dist/*.js"
        }
    },
    "scripts": {
        "lint": "eslint . --fix --cache",
        "prettify": "prettier ./src --write > /dev/null"
    },
    "dependencies": {
        "@nzyme/crypto": "0.14.0",
        "@nzyme/fetch-utils": "0.14.0",
        "@nzyme/ioc": "0.14.0",
        "@nzyme/logging": "0.14.0",
        "@nzyme/rollup-utils": "0.14.0",
        "@nzyme/rpc": "0.14.0",
        "@nzyme/types": "0.14.0",
        "@nzyme/utils": "0.14.0",
        "@superadmin/core": "*",
        "@superadmin/runtime-common": "*",
        "@superadmin/schema": "*",
        "@superadmin/utils": "*",
        "@superadmin/validation": "*",
        "@zod/mini": "4.0.0-beta.0",
        "chalk": "5.6.2",
        "connect": "3.7.0",
        "jose": "6.2.2"
    },
    "devDependencies": {
        "@superadmin/tsconfig": "*",
        "@types/connect": "3.4.38",
        "@types/node": "25.5.0",
        "eslint": "10.1.0",
        "prettier": "3.8.1",
        "typescript": "6.0.2"
    }
}

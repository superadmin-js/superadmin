{
    "name": "@superadmin/config",
    "version": "1.0.0",
    "repository": "https://github.com/kedrzu/superadmin.git",
    "author": "Michał Kędrzyński <m.kedrzynski@gmail.com>",
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "sideEffects": false,
    "scripts": {
        "lint": "eslint . --fix --cache",
        "prettify": "prettier ./src --write > /dev/null"
    },
    "exports": {
        ".": "./dist/index.js",
        "./internal": "./dist/internal.js",
        "./module": "./dist/module.js",
        "./*.js": {
            "types": "./dist/*.d.ts",
            "import": "./dist/*.js",
            "source": "./src/*.ts",
            "default": "./dist/*.js"
        }
    },
    "dependencies": {
        "@nzyme/ioc": "0.14.0",
        "rollup": "4.60.0"
    },
    "devDependencies": {
        "@nzyme/eslint": "0.14.0",
        "@superadmin/tsconfig": "*",
        "@types/node": "25.5.0",
        "eslint": "10.1.0",
        "prettier": "3.8.1"
    }
}

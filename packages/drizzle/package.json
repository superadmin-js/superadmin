{
    "name": "@superadmin/drizzle",
    "version": "1.0.0",
    "author": "Michał Kędrzyński <m.kedrzynski@gmail.com>",
    "repository": "https://github.com/kedrzu/superadmin.git",
    "type": "module",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./*.js": {
            "types": "./dist/*.d.ts",
            "import": "./dist/*.js",
            "source": "./src/*.ts",
            "default": "./dist/*.js"
        }
    },
    "scripts": {
        "lint": "eslint . --fix --cache",
        "prettify": "prettier ./src --write > /dev/null"
    },
    "dependencies": {
        "@superadmin/core": "*",
        "drizzle-orm": "0.45.1"
    },
    "devDependencies": {
        "@superadmin/tsconfig": "*",
        "@types/node": "25.5.0",
        "eslint": "10.1.0",
        "prettier": "3.8.1"
    }
}

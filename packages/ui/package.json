{
    "name": "@superadmin/ui",
    "version": "1.0.0",
    "author": "Michał Kędrzyński <m.kedrzynski@gmail.com>",
    "repository": "https://github.com/kedrzu/superadmin.git",
    "type": "module",
    "sideEffects": false,
    "exports": {
        ".": "./src/index.ts",
        "./theme": "./src/Theme.ts",
        "./package.json": "./package.json",
        "./*.js": "./src/*.ts",
        "./*.jsx": "./src/*.tsx",
        "./*.vue": "./src/*.vue"
    },
    "scripts": {
        "lint": "eslint . --fix --cache",
        "prettify": "prettier ./src --write > /dev/null"
    },
    "dependencies": {
        "@nzyme/crypto": "0.14.0",
        "@nzyme/ioc": "0.14.0",
        "@nzyme/types": "0.14.0",
        "@nzyme/utils": "0.14.0",
        "@nzyme/vue": "0.14.0",
        "@nzyme/vue-ioc": "0.14.0",
        "@nzyme/vue-utils": "0.14.0",
        "@primevue/forms": "4.5.4",
        "@superadmin/client": "*",
        "@superadmin/core": "*",
        "@superadmin/schema": "*",
        "@superadmin/utils": "*",
        "@superadmin/validation": "*",
        "lucide-static": "1.0.1",
        "primevue": "4.5.4",
        "tailwindcss": "4.2.2",
        "vue": "3.5.30",
        "vue-router": "5.0.4"
    },
    "devDependencies": {
        "@superadmin/tsconfig": "*",
        "@types/node": "25.5.0",
        "eslint": "10.1.0",
        "prettier": "3.8.1"
    }
}

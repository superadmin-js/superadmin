{
    "name": "@superadmin/schema",
    "version": "1.0.0",
    "repository": "https://github.com/kedrzu/superadmin.git",
    "author": "Michał Kędrzyński <m.kedrzynski@gmail.com>",
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "sideEffects": false,
    "scripts": {
        "lint": "eslint . --fix --cache",
        "prettify": "prettier ./src --write > /dev/null"
    },
    "dependencies": {
        "@nzyme/utils": "0.14.0",
        "@nzyme/zchema": "0.14.0",
        "lucide-static": "0.577.0"
    },
    "devDependencies": {
        "@superadmin/tsconfig": "*",
        "@types/node": "25.5.0",
        "eslint": "10.0.3",
        "prettier": "3.8.1"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./*.js": {
            "types": "./dist/*.d.ts",
            "import": "./dist/*.js",
            "source": "./src/*.ts",
            "default": "./dist/*.js"
        }
    }
}

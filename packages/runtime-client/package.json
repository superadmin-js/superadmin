{
    "name": "@superadmin/runtime-client",
    "version": "1.0.0",
    "author": "Michał Kędrzyński <m.kedrzynski@gmail.com>",
    "repository": "https://github.com/kedrzu/superadmin.git",
    "type": "module",
    "sideEffects": false,
    "main": "./src/index.ts",
    "module": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
        "./module": {
            "types": "./src/module.ts",
            "import": "./src/module.ts",
            "default": "./src/module.ts"
        },
        "./package.json": "./package.json"
    },
    "scripts": {
        "lint": "eslint . --fix --cache",
        "format": "oxfmt ./src > /dev/null"
    },
    "dependencies": {
        "@nzyme/crypto": "0.14.0",
        "@nzyme/ioc": "0.14.0",
        "@nzyme/types": "0.14.0",
        "@nzyme/utils": "0.14.0",
        "@nzyme/vue": "0.14.0",
        "@nzyme/vue-ioc": "0.14.0",
        "@nzyme/vue-utils": "0.14.0",
        "@primevue/themes": "4.5.4",
        "@superadmin/client": "*",
        "@superadmin/core": "*",
        "@superadmin/runtime-common": "*",
        "@superadmin/schema": "*",
        "@superadmin/ui": "*",
        "@superadmin/utils": "*",
        "@superadmin/validation": "*",
        "debug": "4.4.3",
        "primevue": "4.5.4",
        "tailwindcss": "4.2.2",
        "tailwindcss-primeui": "0.6.1",
        "vue": "3.5.30",
        "vue-router": "5.0.4"
    },
    "devDependencies": {
        "@nzyme/rollup-utils": "0.14.0",
        "@superadmin/tsconfig": "*",
        "@types/debug": "4.1.13",
        "@types/node": "25.5.0",
        "@vue/tsconfig": "0.9.1",
        "eslint": "10.1.0",
        "oxfmt": "0.46.0",
        "vite": "7.3.1"
    }
